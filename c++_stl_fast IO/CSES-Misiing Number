#include<bits/stdc++.h>
using namespace std;

int main(){
  ios::sync_with_stdio(false);
  cin.tie(nullptr);

  long long n;
  cin >> n;

  long long total = n * (n + 1) / 2;
  long long sum = 0;
  long long x;

  for(long long i = 0; i < n - 1; i++){
    cin >> x;
    sum += x;
  }

  cout << total - sum;

  return 0;
}
