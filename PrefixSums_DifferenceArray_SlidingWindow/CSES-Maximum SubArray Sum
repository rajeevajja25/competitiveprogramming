#include <bits/stdc++.h>
using namespace std;
 
int main()
{
    int n;
 
    cin >> n;
    vector<long long> v(n);
   
    for(int i = 0; i < n; i++)
    {
        cin >> v[i];
    }
 
   
   long long curr=v[0];
   long long best=v[0];
 
  for(int i=1;i<n;i++){
    curr=max(v[i],curr+v[i]);
    best=max(best,curr);
 
 
 
}
 
cout<<best;
}
