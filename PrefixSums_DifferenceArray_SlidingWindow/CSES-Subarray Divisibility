#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    cin >> n;

    vector<long long> v(n), p(n + 1);

    for(int i = 0; i < n; i++)
    {
        cin >> v[i];
    }

    p[0] = 0;

    for(int i = 0; i < n; i++)
    {
        p[i + 1] = p[i] + v[i];
    }

    map<long long,long long> freq;

    freq[0] = 1;

    long long ans = 0;

    for(int i = 1; i <= n; i++)
    {
        long long rem = ((p[i] % n) + n) % n;

        ans += freq[rem];

        freq[rem]++;
    }

    cout << ans;
}
