#include <iostream>
#include <vector>
using namespace std;
int main(){
long long sum=0;
int left=0;
int x;
long long count=0;
int n;
cin>>n>>x;
vector<int>a(n);
 for (int i = 0; i < n; i++){
        cin >> a[i];
}
for(int right=0;right<n;right++){

  sum+=a[right];
 
   while(sum>x){
     sum-=a[left];
      left++;

  }
  if(sum==x)
    count++;
    
}
cout<<count;
}
