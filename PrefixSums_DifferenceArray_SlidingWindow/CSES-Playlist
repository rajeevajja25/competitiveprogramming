#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    cin >> n ;
    vector<long long> v(n);
   
    for(int i = 0; i < n; i++)
    {
        cin >> v[i];
    }

   
    map<long long, long long> freq;

    long long best=0;
    int left=0;
    
    for(int right = 0; right < n; right++)

    {
          freq[v[right]]++;
         while(freq[v[right]]>1){
           freq[v[left]]--;
           left++;



}

 best=max(best,right-left+1)


            }
    
    cout << best;
}
