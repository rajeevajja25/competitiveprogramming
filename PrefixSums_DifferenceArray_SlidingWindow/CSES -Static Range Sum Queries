#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, q;
    cin >> n >> q;
    vector<long long> v(n + 1), p(n + 1, 0);

    for (int i = 1; i <= n; i++) {
        cin >> v[i];
    }
    for (int i = 1; i <= n; i++) {
        p[i] = p[i - 1] + v[i];
    }
    while (q--) {
        int l, r;
        cin >> l >> r;

        cout << p[r] - p[l - 1] << '\n';
    }

    return 0;
}
