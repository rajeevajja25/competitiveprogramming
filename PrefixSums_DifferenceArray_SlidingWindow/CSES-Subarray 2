#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    long long x;
    cin >> n >> x;

    vector<long long> v(n);
    vector<long long> p(n + 1);

    for(int i = 0; i < n; i++)
    {
        cin >> v[i];
    }

    p[0] = 0;

    for(int i = 0; i < n; i++)
    {
        p[i + 1] = p[i] + v[i];
    }

    map<long long, long long> freq;

    long long ans = 0;

    for(int i = 0; i <= n; i++)
    {
        ans += freq[p[i] - x];
        freq[p[i]]++;
    }

    cout << ans;
